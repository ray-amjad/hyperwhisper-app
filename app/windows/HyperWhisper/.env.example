# Sentry Configuration for Debug Symbol Upload
# Copy this file to .env and fill in your values
# These are used during Release builds to upload PDB files to Sentry

# Your Sentry organization slug (found in Sentry URL: sentry.io/organizations/YOUR_ORG/)
SENTRY_ORG=your-org-slug

# Your Sentry project slug (found in project settings)
SENTRY_PROJECT=hyperwhisper

# Sentry Auth Token (create at: https://sentry.io/settings/auth-tokens/)
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=your-auth-token-here
