<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DARK THEME COLORS
         Dark mode color palette for HyperWhisper Windows app.
         Follows macOS HyperWhisper design language with dark backgrounds
         and light text for reduced eye strain in low-light environments.
    -->

    <!-- Primary Accent Colors (slightly brighter for dark backgrounds) -->
    <Color x:Key="AccentColor">#0A84FF</Color>
    <Color x:Key="AccentColorHover">#2997FF</Color>
    <Color x:Key="AccentColorPressed">#006EDB</Color>

    <!-- Sidebar Icon Colors (consistent across themes for brand recognition) -->
    <Color x:Key="HomeIconColor">#FF6B6B</Color>
    <Color x:Key="HistoryIconColor">#4ECDC4</Color>
    <Color x:Key="ModesIconColor">#45B7D1</Color>
    <Color x:Key="VocabularyIconColor">#F9CA24</Color>
    <Color x:Key="SettingsIconColor">#95A5A6</Color>

    <!-- Status Colors (slightly adjusted for dark backgrounds) -->
    <Color x:Key="SuccessColor">#30D158</Color>
    <Color x:Key="WarningColor">#FF9F0A</Color>
    <Color x:Key="ErrorColor">#FF453A</Color>
    <Color x:Key="ProcessingColor">#5E5CE6</Color>
    <Color x:Key="PostProcessingColor">#BF5AF2</Color>

    <!-- Dark Theme Background Colors -->
    <Color x:Key="SidebarBackground">#E6222326</Color>
    <Color x:Key="ContentBackground">#F0151517</Color>
    <Color x:Key="CardBackground">#F21D1D20</Color>
    <Color x:Key="InputBackground">#F2242428</Color>
    <Color x:Key="HoverBackground">#303035</Color>
    <Color x:Key="SelectedBackground">#183D66</Color>
    <Color x:Key="BorderColor">#B034343A</Color>

    <!-- Dark Theme Text Colors -->
    <Color x:Key="TextPrimary">#F5F5F7</Color>
    <Color x:Key="TextSecondary">#A1A1A6</Color>
    <Color x:Key="TextTertiary">#6E6E73</Color>
    <Color x:Key="TextOnAccent">#FFFFFF</Color>

    <!-- Semantic Alert Colors - Warning (Yellow/Amber) -->
    <Color x:Key="WarningBackground">#4D3800</Color>
    <Color x:Key="WarningForeground">#FFD666</Color>
    <Color x:Key="WarningBorder">#665200</Color>

    <!-- Semantic Alert Colors - Error (Red) -->
    <Color x:Key="ErrorBackground">#4D1F24</Color>
    <Color x:Key="ErrorForeground">#FF8A8A</Color>
    <Color x:Key="ErrorBorder">#662A30</Color>

    <!-- Semantic Alert Colors - Info (Blue) -->
    <Color x:Key="InfoBackground">#0D3A5C</Color>
    <Color x:Key="InfoForeground">#6DB3F2</Color>
    <Color x:Key="InfoBorder">#1A5A8A</Color>

    <!-- Semantic Alert Colors - Success (Green) -->
    <Color x:Key="SuccessBackground">#1A3D24</Color>
    <Color x:Key="SuccessForeground">#7DD694</Color>
    <Color x:Key="SuccessBorder">#2A5C38</Color>

    <!-- Badge Colors -->
    <Color x:Key="BadgeGrayBackground">#3A3A3C</Color>
    <Color x:Key="BadgeGrayForeground">#AEAEB2</Color>

    <!-- Progress Bar -->
    <Color x:Key="ProgressBackground">#48484A</Color>

    <!-- Hover States -->
    <Color x:Key="DeleteHoverBackground">#4D1F24</Color>

    <!-- Statistics Colors -->
    <Color x:Key="StatisticsIconColor">#818CF8</Color>
    <Color x:Key="StatisticsBlue">#60A5FA</Color>
    <Color x:Key="StatisticsGreen">#4ADE80</Color>
    <Color x:Key="StatisticsPurple">#C084FC</Color>
    <Color x:Key="StatisticsOrange">#FB923C</Color>
    <Color x:Key="StatisticsChartBar">#818CF8</Color>

</ResourceDictionary>
