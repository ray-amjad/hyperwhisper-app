<Page x:Class="HyperWhisper.Views.Pages.ModesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      Title="{loc:Loc modes.header.title}" Background="{DynamicResource ContentBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header with Title and Create Button -->
        <Border Grid.Row="0" Padding="24,20" Background="{DynamicResource ContentBackgroundBrush}">
            <Grid MaxWidth="{StaticResource ContentMaxWidthWide}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{loc:Loc modes.header.title}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{loc:Loc modes.header.subtitle}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="{loc:Loc modes.header.create}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Top"
                        Click="CreateMode_Click"/>
            </Grid>
        </Border>

        <Separator Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" MaxWidth="{StaticResource ContentMaxWidthWide}">
            <!-- MODE CARD GRID
                 Cards are arranged in a 2-column grid with consistent spacing.
                 - Horizontal gap between cards: 8px (4px margin on each side)
                 - Vertical gap between cards: 8px (4px margin on each side)
                 - No extra margin at edges (grid aligns with page title) -->
            <ListBox x:Name="ModeListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="-4,0,-4,0"
                     SelectionChanged="ModeListBox_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                        <!-- 6px margin creates 12px gaps between cards -->
                        <Setter Property="Margin" Value="6"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <!-- Outer border for selection highlight -->
                                    <Border x:Name="SelectionBorder"
                                            CornerRadius="10"
                                            BorderThickness="2"
                                            BorderBrush="Transparent">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- Selected state: show accent border -->
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <!-- Hover state: show subtle border when not selected -->
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource CardCornerRadius}"
                                Padding="16"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource BorderBrush}"
                                Loaded="ModeCard_Loaded">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Header with Name, Offline Badge, and Settings -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Mode Name (accent color when selected) -->
                                    <TextBlock x:Name="ModeNameText"
                                               Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>

                                    <!-- Offline Badge (inline with name) -->
                                    <Border x:Name="OfflineBadge"
                                            Grid.Column="1"
                                            Background="{DynamicResource SuccessBackgroundBrush}"
                                            CornerRadius="4"
                                            Padding="5,2"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8A7;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{loc:Loc modes.badge.offline}"
                                                       FontSize="9"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource SuccessBrush}"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Settings Button -->
                                    <Button Grid.Column="2"
                                            Click="EditMode_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4"
                                            Margin="4,0,0,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Tag="{Binding}">
                                        <TextBlock Text="&#xE713;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    </Button>
                                </Grid>

                                <!-- Row 1: Language -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="&#xE774;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Language, Converter={StaticResource LanguageCodeToDisplayNameConverter}}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 2: Provider/Model Info + Post-Processing (inline) -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <!-- Cloud Provider (visible for cloud modes) -->
                                    <StackPanel x:Name="CloudProviderPanel"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                        <TextBlock Text="&#xE753;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="CloudProviderText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Local Model (visible for local modes) -->
                                    <StackPanel x:Name="LocalModelPanel"
                                                Orientation="Horizontal"
                                                Visibility="Collapsed">
                                        <TextBlock x:Name="LocalModelIcon"
                                                   Text="&#xE964;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LocalModelText"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Post-Processing inline (conditional) -->
                                    <StackPanel x:Name="PostProcessingPanel"
                                                Orientation="Horizontal"
                                                Visibility="{Binding Path=., Converter={StaticResource PostProcessingVisibilityConverter}}">
                                        <TextBlock Text=" · "
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="&#xE945;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource PostProcessingBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Path=., Converter={StaticResource PostProcessingDisplayConverter}}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource PostProcessingBrush}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <!-- Show "Offline" badge when mode is offline-capable -->
                            <DataTrigger Binding="{Binding IsOfflineCapable}" Value="True">
                                <Setter TargetName="OfflineBadge" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Cloud provider visibility -->
                            <DataTrigger Binding="{Binding ProviderType}" Value="cloud">
                                <Setter TargetName="CloudProviderPanel" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Local provider visibility -->
                            <DataTrigger Binding="{Binding ProviderType}" Value="local">
                                <Setter TargetName="LocalModelPanel" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Selected state: accent color for mode name -->
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="ModeNameText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
