<Page x:Class="HyperWhisper.Views.Pages.VocabularyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      Title="{loc:Loc vocabulary.title}"
      Background="{DynamicResource ContentBackgroundBrush}">
    <Page.Resources>
        <!-- Single keyboard-key chip (e.g. "Ctrl" or "↵"). -->
        <Style x:Key="KeyboardGlyphStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Inline tappable label + key glyphs. Dims to ~35% when disabled so the
             user can see the shortcut but knows it won't fire yet. -->
        <Style x:Key="ActionChipStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,20" Background="{DynamicResource ContentBackgroundBrush}">
            <StackPanel MaxWidth="{StaticResource ContentMaxWidthWide}">
                <TextBlock Text="{loc:Loc vocabulary.title}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{loc:Loc vocabulary.description}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Separator Grid.Row="1" Background="{DynamicResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RootStack" Margin="24,24,24,24" MaxWidth="{StaticResource ContentMaxWidthWide}">

            <!-- Deepgram-style keyword limit notice -->
            <Border x:Name="WarningBanner"
                    Visibility="Collapsed"
                    Background="{DynamicResource WarningBackgroundBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="12"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="{loc:Loc vocabulary.limit.title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource WarningForegroundBrush}"/>
                    <TextBlock x:Name="WarningText"
                               FontSize="12"
                               Foreground="{DynamicResource WarningForegroundBrush}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Input Form -->
            <StackPanel x:Name="InputSection" Margin="0,0,0,16">

                <!-- Word input row -->
                <Border Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <TextBox x:Name="WordBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     PreviewKeyDown="WordBox_PreviewKeyDown"
                                     TextChanged="WordBox_TextChanged"/>
                            <TextBlock x:Name="WordPlaceholder"
                                       Text="{loc:Loc vocabulary.input.placeholder}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="14"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="14,0,0,0">
                            <Button x:Name="AddWordChip"
                                    Style="{StaticResource ActionChipStyle}"
                                    Click="AddWordChip_Click"
                                    Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="AddWordChipLabel"
                                               Text="{loc:Loc vocabulary.action.addWord}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Style="{StaticResource KeyboardGlyphStyle}">
                                        <TextBlock Text="&#x21B5;"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ReplaceWithChip"
                                    Style="{StaticResource ActionChipStyle}"
                                    Click="ReplaceWithChip_Click"
                                    Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc vocabulary.action.replaceWith}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Style="{StaticResource KeyboardGlyphStyle}" Margin="0,0,3,0">
                                        <TextBlock Text="Ctrl"
                                                   FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource KeyboardGlyphStyle}">
                                        <TextBlock Text="&#x21B5;"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Button>

                            <Button x:Name="CancelButton"
                                    Content="{loc:Loc common.cancel}"
                                    Visibility="Collapsed"
                                    Padding="10,4"
                                    Background="Transparent"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                    FontSize="12"
                                    Cursor="Hand"
                                    Click="CancelButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Replacement field row (revealed by Ctrl+Enter or chip click) -->
                <Border x:Name="ReplacementBorder"
                        Visibility="Collapsed"
                        Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" MinHeight="64">
                            <TextBox x:Name="ReplacementBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     FontSize="14"
                                     AcceptsReturn="False"
                                     TextWrapping="Wrap"
                                     VerticalAlignment="Top"
                                     VerticalContentAlignment="Top"
                                     PreviewKeyDown="ReplacementBox_PreviewKeyDown"
                                     TextChanged="ReplacementBox_TextChanged"/>
                            <TextBlock x:Name="ReplacementPlaceholder"
                                       Text="{loc:Loc vocabulary.replacement.field.placeholder}"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       FontSize="14"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Top"
                                       Margin="0,0,0,0"/>
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button x:Name="ReplaceChip"
                                    Style="{StaticResource ActionChipStyle}"
                                    Click="ReplaceChip_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc vocabulary.action.replace}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <Border Style="{StaticResource KeyboardGlyphStyle}" Margin="0,0,3,0">
                                        <TextBlock Text="Ctrl"
                                                   FontSize="10"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Style="{StaticResource KeyboardGlyphStyle}">
                                        <TextBlock Text="&#x21B5;"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource ErrorForegroundBrush}"
                           FontSize="12"
                           Margin="0,8,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Vocabulary List -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="0">
                <StackPanel>
                    <Border Background="{DynamicResource SidebarBackgroundBrush}"
                            Padding="16,8"
                            CornerRadius="9,9,0,0">
                        <Grid x:Name="HeaderRow">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{loc:Loc vocabulary.word.column}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{loc:Loc vocabulary.replacement.column}"
                                       Grid.Column="1"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{loc:Loc vocabulary.source.column}"
                                       Grid.Column="2"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text=""
                                       Grid.Column="3"/>
                        </Grid>
                    </Border>

                    <StackPanel x:Name="EmptyState" Visibility="Collapsed" Margin="40" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8F1;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="48"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="{loc:Loc vocabulary.empty.title}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{loc:Loc vocabulary.empty.subtitle}"
                                   FontSize="13"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <ListView x:Name="VocabularyList"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Word}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Replacement}"
                                                   Grid.Column="1"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource SidebarBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding IsSourceVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock Text="{Binding SourceBadgeText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Tag="{Binding Id}"
                                                    Click="EditButton_Click"
                                                    ToolTip="{loc:Loc common.edit}">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="13"/>
                                            </Button>
                                            <Button Width="32"
                                                    Height="32"
                                                    Padding="0"
                                                    Margin="4,0,0,0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Tag="{Binding Id}"
                                                    Click="DeleteButton_Click"
                                                    ToolTip="{loc:Loc common.delete}">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="13"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
