<Page x:Class="HyperWhisper.Views.Pages.Settings.BackupExportSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidthForm}">
            <TextBlock Text="{loc:Loc settings.section.backup}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- Export Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Export Button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc settings.backup.export.title}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.backup.export.subtitle}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button x:Name="ExportButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Grid.Column="1"
                                Content="{loc:Loc settings.backup.export.button}"
                                Click="ExportButton_Click"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10,0,10"/>

                    <!-- Section selection -->
                    <TextBlock Text="{loc:Loc settings.backup.export.sections.header}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,6"/>

                    <CheckBox x:Name="ExportSettingsCheckbox"
                              Content="{loc:Loc settings.backup.export.section.settings}"
                              IsChecked="True" Margin="0,0,0,4"
                              Checked="ExportSection_Changed" Unchecked="ExportSection_Changed"/>
                    <CheckBox x:Name="ExportModesCheckbox"
                              Content="{loc:Loc settings.backup.export.section.modes}"
                              IsChecked="True" Margin="0,0,0,4"
                              Checked="ExportSection_Changed" Unchecked="ExportSection_Changed"/>
                    <CheckBox x:Name="ExportVocabularyCheckbox"
                              IsChecked="True" Margin="0,0,0,4"
                              Checked="ExportSection_Changed" Unchecked="ExportSection_Changed"/>

                    <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10,0,10"/>

                    <!-- Include API Keys Toggle -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc settings.backup.export.includeApiKeys}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.backup.export.apiKeysWarning}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="IncludeApiKeysCheckbox" Grid.Column="1" VerticalAlignment="Center"
                                  Checked="ExportSection_Changed" Unchecked="ExportSection_Changed"/>
                    </Grid>

                    <!-- Export Status -->
                    <TextBlock x:Name="ExportStatusText"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Import Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Choose File Button -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc settings.backup.import.title}"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.backup.import.subtitle}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button x:Name="ChooseFileButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Grid.Column="1"
                                Content="{loc:Loc settings.backup.import.chooseFile}"
                                Click="ChooseFileButton_Click"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Selective import panel (revealed after a file is inspected) -->
                    <StackPanel x:Name="ImportSelectionPanel" Visibility="Collapsed">
                        <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10,0,10"/>

                        <TextBlock x:Name="ImportContainsText"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <CheckBox x:Name="ImportSettingsCheckbox"
                                  Content="{loc:Loc settings.backup.import.section.settings}"
                                  Margin="0,0,0,4"/>
                        <CheckBox x:Name="ImportModesCheckbox"
                                  Content="{loc:Loc settings.backup.import.section.modes}"
                                  Margin="0,0,0,4"/>
                        <CheckBox x:Name="ImportVocabularyCheckbox"
                                  Margin="0,0,0,4"/>
                        <CheckBox x:Name="ImportApiKeysCheckbox"
                                  Content="{loc:Loc settings.backup.import.section.apiKeys}"
                                  Margin="0,0,0,4"/>

                        <!-- Vocabulary conflict policy (shown only when vocabulary is present) -->
                        <StackPanel x:Name="VocabConflictPanel" Margin="20,6,0,0">
                            <TextBlock Text="{loc:Loc settings.backup.import.vocabConflict.header}"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4"/>
                            <RadioButton x:Name="VocabConflictSkipRadio"
                                         GroupName="VocabConflict"
                                         Content="{loc:Loc settings.backup.import.vocabConflict.skip}"
                                         IsChecked="True" Margin="0,0,0,2"/>
                            <RadioButton x:Name="VocabConflictReplaceRadio"
                                         GroupName="VocabConflict"
                                         Content="{loc:Loc settings.backup.import.vocabConflict.replace}"/>
                        </StackPanel>

                        <Button x:Name="ImportSelectedButton"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Content="{loc:Loc settings.backup.import.applyButton}"
                                Click="ImportSelectedButton_Click"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- Import Status -->
                    <TextBlock x:Name="ImportStatusText"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Info Notice -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Top" Margin="0,1,8,0"/>
                <TextBlock Text="{loc:Loc settings.backup.notice}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
