<Page x:Class="HyperWhisper.Views.Pages.Settings.SoundSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidthForm}">
            <TextBlock Text="{loc:Loc settings.sound.title}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- Sound Effects Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{loc:Loc settings.sound.enableSoundEffects.title}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc settings.sound.enableSoundEffects.subtitle}"
                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <CheckBox x:Name="EnableSoundEffectsCheckbox" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="EnableSoundEffectsCheckbox_Checked"
                              Unchecked="EnableSoundEffectsCheckbox_Unchecked"/>
                </Grid>
            </Border>

            <!-- Media Control Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Loc settings.sound.mediaControl.title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.sound.mediaControl.subtitle}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ComboBox x:Name="MediaControlModeComboBox" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  SelectionChanged="MediaControlModeComboBox_SelectionChanged">
                            <ComboBoxItem Tag="off" Content="{loc:Loc settings.sound.mediaControl.off}"/>
                            <ComboBoxItem Tag="muteAudio" Content="{loc:Loc settings.sound.mediaControl.muteAudio}"/>
                        </ComboBox>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Microphone Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Auto-increase Mic Volume -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Loc settings.sound.autoIncreaseMicVolume.title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.sound.autoIncreaseMicVolume.subtitle}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <CheckBox x:Name="AutoIncreaseMicVolumeCheckbox" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="AutoIncreaseMicVolumeCheckbox_Checked"
                                  Unchecked="AutoIncreaseMicVolumeCheckbox_Unchecked"/>
                    </Grid>

                    <!-- Keep Microphone Warm -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Loc settings.sound.keepMicrophoneWarm.title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{loc:Loc settings.sound.keepMicrophoneWarm.subtitle}"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <CheckBox x:Name="KeepMicrophoneWarmCheckbox" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="KeepMicrophoneWarmCheckbox_Checked"
                                  Unchecked="KeepMicrophoneWarmCheckbox_Unchecked"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
