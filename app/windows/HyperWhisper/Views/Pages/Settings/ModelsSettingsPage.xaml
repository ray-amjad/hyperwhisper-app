<Page x:Class="HyperWhisper.Views.Pages.Settings.ModelsSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      xmlns:controls="clr-namespace:HyperWhisper.Views.Controls"
      Background="{DynamicResource ContentBackgroundBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24,20"
                Background="{DynamicResource ContentBackgroundBrush}">
            <StackPanel MaxWidth="{StaticResource ContentMaxWidthWide}">
                <TextBlock Text="Model Library"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="LibrarySummaryText"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Separator Grid.Row="1"
                   Background="{DynamicResource BorderBrush}"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="{StaticResource ContentMaxWidthWide}" Margin="24,24,24,24">

            <Border x:Name="ModelsTrialWarning"
                    Background="{DynamicResource WarningBackgroundBrush}"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="16"
                    Margin="0,0,0,14"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="ModelsTrialWarningTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningForegroundBrush}"/>
                        <TextBlock x:Name="ModelsTrialWarningText" FontSize="13"
                                   Foreground="{DynamicResource WarningForegroundBrush}"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{loc:Loc settings.license.upgrade.button}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Click="ModelsUpgrade_Click"/>
                </Grid>
            </Border>

            <!-- Search pill with inline filter chips + integrated filter dropdown (mirrors the macOS Model Library). -->
            <Border Background="{DynamicResource InputBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12,7"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"
                             FontSize="13"
                             Padding="0"
                             TextChanged="Filter_Changed"/>

                    <!-- Inline clearable chips for active filters. -->
                    <StackPanel x:Name="ActiveFilterChipsPanel" Grid.Column="2"
                                Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="8,0,0,0" Visibility="Collapsed">
                        <Border x:Name="TypeFilterChip"
                                Background="{DynamicResource BadgeGrayBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="11" Padding="8,2" Margin="4,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TypeFilterChipText" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button Margin="6,0,0,0" Padding="0" Width="14" Height="14"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Click="TypeFilterChip_Clear" ToolTip="Clear filter">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               LineStackingStrategy="BlockLineHeight" LineHeight="9"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="LocationFilterChip"
                                Background="{DynamicResource BadgeGrayBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="11" Padding="8,2" Margin="4,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="LocationFilterChipText" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button Margin="6,0,0,0" Padding="0" Width="14" Height="14"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Click="LocationFilterChip_Clear" ToolTip="Clear filter">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               LineStackingStrategy="BlockLineHeight" LineHeight="9"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="VocabFilterChip"
                                Background="{DynamicResource BadgeGrayBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="11" Padding="8,2" Margin="4,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Custom vocabulary" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button Margin="6,0,0,0" Padding="0" Width="14" Height="14"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Click="VocabFilterChip_Clear" ToolTip="Clear filter">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               LineStackingStrategy="BlockLineHeight" LineHeight="9"/>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="CloudAvailableFilterChip"
                                Background="{DynamicResource BadgeGrayBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                CornerRadius="11" Padding="8,2" Margin="4,0,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="On HyperWhisper Cloud" FontSize="11"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <Button Margin="6,0,0,0" Padding="0" Width="14" Height="14"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        Click="CloudAvailableFilterChip_Clear" ToolTip="Clear filter">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               LineStackingStrategy="BlockLineHeight" LineHeight="9"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Filter dropdown: checkable Type / Location / Features (mirrors macOS). -->
                    <Button x:Name="FilterButton" Grid.Column="3" Margin="8,0,0,0"
                            Background="Transparent" BorderThickness="0" Padding="2,0"
                            Cursor="Hand" ToolTip="Filter"
                            Click="FilterButton_Click">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="FilterMenu" Placement="Bottom">
                                <MenuItem Header="Type" IsEnabled="False"/>
                                <MenuItem x:Name="TypeVoiceMenuItem" Header="Voice models"
                                          IsCheckable="True" Click="TypeFilter_Changed"/>
                                <MenuItem x:Name="TypeLanguageMenuItem" Header="Language models"
                                          IsCheckable="True" Click="TypeFilter_Changed"/>
                                <Separator/>
                                <MenuItem Header="Location" IsEnabled="False"/>
                                <MenuItem x:Name="LocationCloudMenuItem" Header="Cloud"
                                          IsCheckable="True" Click="LocationFilter_Changed"/>
                                <MenuItem x:Name="LocationOfflineMenuItem" Header="Offline"
                                          IsCheckable="True" Click="LocationFilter_Changed"/>
                                <Separator/>
                                <MenuItem Header="Features" IsEnabled="False"/>
                                <MenuItem x:Name="VocabFilterMenuItem" Header="Supports custom vocabulary"
                                          IsCheckable="True" Click="FeatureFilter_Changed"/>
                                <MenuItem x:Name="CloudAvailableFilterMenuItem" Header="Available on HyperWhisper Cloud"
                                          IsCheckable="True" Click="FeatureFilter_Changed"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter strip: provider dropdown (left) + API keys / secrets button (right). -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="ProviderButton"
                        Height="30" Padding="10,0"
                        Background="{DynamicResource InputBackgroundBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Cursor="Hand"
                        Click="ProviderButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ProviderFilterLabel" Text="All providers" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="ProviderMenu" Placement="Bottom">
                            <MenuItem Header="All providers" IsCheckable="True" IsChecked="True"
                                      Tag="All providers" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="OpenAI" IsCheckable="True" Tag="OpenAI" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="Anthropic" IsCheckable="True" Tag="Anthropic" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="Groq" IsCheckable="True" Tag="Groq" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="Deepgram" IsCheckable="True" Tag="Deepgram" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="Gemini" IsCheckable="True" Tag="Gemini" Click="ProviderFilter_Changed"/>
                            <MenuItem Header="Local" IsCheckable="True" Tag="Local" Click="ProviderFilter_Changed"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Language filter: dropdown + "N of M support X" count + Show all. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="10,0,0,0" VerticalAlignment="Center">
                    <Button x:Name="LanguageButton"
                            Height="30" Padding="10,0"
                            Background="{DynamicResource InputBackgroundBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Cursor="Hand" ToolTip="Filter models by language"
                            Click="LanguageButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="LanguageFilterLabel" Text="Language" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="LanguageMenu" Placement="Bottom"/>
                        </Button.ContextMenu>
                    </Button>
                    <TextBlock x:Name="LanguageCountText" FontSize="12" VerticalAlignment="Center"
                               Margin="10,0,0,0" Visibility="Collapsed"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Button x:Name="LanguageShowAllButton" Content="Show all"
                            Margin="8,0,0,0" Padding="0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            FontSize="12" VerticalAlignment="Center" Visibility="Collapsed"
                            Foreground="{DynamicResource AccentBrush}"
                            Click="LanguageShowAll_Click"/>
                </StackPanel>

                <Button x:Name="SecretsButton" Grid.Column="2"
                        Height="30" Padding="10,0"
                        Background="{DynamicResource InputBackgroundBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Cursor="Hand" ToolTip="Manage API keys"
                        Click="OpenApiKeys_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE192;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                        <TextBlock Text="API keys" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="0"
                    Margin="0,0,0,14">
                <StackPanel>
                    <Grid Margin="14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="210"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="NameSortHeader"
                                Grid.Column="0"
                                Tag="Name"
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Click="SortHeader_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Model name" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="NameSortGlyph"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="9"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="TypeSortHeader"
                                Grid.Column="1"
                                Tag="Type"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Click="SortHeader_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Type" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="TypeSortGlyph"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="9"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="RatingSortHeader"
                                Grid.Column="2"
                                Tag="Rating"
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Click="SortHeader_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Speed / Accuracy" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="RatingSortGlyph"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="9"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="LocationSortHeader"
                                Grid.Column="3"
                                Tag="Location"
                                HorizontalAlignment="Right"
                                HorizontalContentAlignment="Right"
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Click="SortHeader_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Cloud / Offline" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LocationSortGlyph"
                                           Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="9"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Border Height="1" Background="{DynamicResource BorderBrush}"/>

                    <ListBox x:Name="LibraryRowsControl"
                             ItemsSource="{Binding LibraryRows}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="False"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid Margin="14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="210"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Col 0: provider tile + name / tags / provider -->
                                        <Grid Grid.Column="0" ToolTip="{Binding DetailToolTip}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="7"
                                                    Background="{DynamicResource InputBackgroundBrush}"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <Image Source="{Binding ProviderAssetPath}"
                                                       Width="22" Height="22"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="280"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Border Background="{DynamicResource BadgeGrayBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="9"
                                                            Padding="6,1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding TagVisibility}">
                                                        <TextBlock Text="{Binding TagText}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ProviderName}"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,1,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Col 1: type glyph (Voice / Text) -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding KindGlyph}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding KindToolTip}"/>

                                        <!-- Col 2: speed / accuracy gauges -->
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                            <controls:GaugeBar Rating="{Binding Speed}"
                                                               FilledBrushKey="{Binding GaugeBrushKey}"
                                                               ToolTip="Speed"/>
                                            <controls:GaugeBar Rating="{Binding Accuracy}"
                                                               FilledBrushKey="{Binding GaugeBrushKey}"
                                                               Margin="0,4,0,0"
                                                               ToolTip="Accuracy"/>
                                        </StackPanel>

                                        <!-- Col 3: cloud/offline size + actions -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SizeText}"
                                                       Visibility="{Binding SizeVisibility}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <Button Tag="{Binding}"
                                                    MinHeight="30"
                                                    MinWidth="92"
                                                    Padding="8,5"
                                                    Click="LibraryRowPrimaryAction_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="14"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StatusGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"
                                                               LineStackingStrategy="BlockLineHeight"
                                                               LineHeight="12"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding StatusText}"
                                                               FontSize="12"
                                                               Margin="6,0,0,0"
                                                               MaxWidth="120"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Button>
                                            <Button Tag="{Binding}" Width="30" Height="30" Padding="0"
                                                    Margin="6,0,0,0"
                                                    Visibility="{Binding CancelVisibility}"
                                                    Click="LibraryRowCancel_Click">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="12"/>
                                            </Button>
                                            <Button Tag="{Binding}" Width="30" Height="30" Padding="0"
                                                    Margin="6,0,0,0"
                                                    Visibility="{Binding DuplicateVisibility}"
                                                    Click="LibraryRowDuplicate_Click">
                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="12"/>
                                            </Button>
                                            <Button Tag="{Binding}" Width="30" Height="30" Padding="0"
                                                    Margin="6,0,0,0"
                                                    Visibility="{Binding DeleteVisibility}"
                                                    Click="LibraryRowDelete_Click">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           LineStackingStrategy="BlockLineHeight"
                                                           LineHeight="12"/>
                                            </Button>
                                        </StackPanel>
                                        <ProgressBar Grid.Column="0" Grid.ColumnSpan="4"
                                                     Height="3"
                                                     VerticalAlignment="Bottom"
                                                     Margin="42,0,0,-8"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding DownloadProgress, Mode=OneWay}"
                                                     Visibility="{Binding DownloadProgressVisibility}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel x:Name="EmptyStatePanel"
                                HorizontalAlignment="Center"
                                Margin="0,40"
                                Visibility="Collapsed">
                        <TextBlock x:Name="EmptyStateText"
                                   Text="{loc:Loc settings.models.empty.noMatches}"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="560"/>
                        <Button x:Name="ClearFiltersButton"
                                Content="{loc:Loc settings.models.clearFilters}"
                                Padding="12,6"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Center"
                                Click="ClearFilters_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,14">
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="&#xE785;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="Enabled"
                               FontSize="11"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock Text="&#xE72E;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="Locked"
                               FontSize="11"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0">
                    <TextBlock Text="&#xE7BA;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="Key invalid"
                               FontSize="11"
                               Margin="6,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>

            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="12"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="OpenAI-compatible endpoints"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="CustomEndpointsSummaryText"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Padding="12,6"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Click="AddCustomEndpoint_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="12"/>
                            <TextBlock Text="Add Endpoint" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
