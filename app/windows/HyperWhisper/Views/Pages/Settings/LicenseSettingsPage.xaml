<Page x:Class="HyperWhisper.Views.Pages.Settings.LicenseSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:loc="clr-namespace:HyperWhisper.Localization"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="{StaticResource PagePadding}">
        <StackPanel MaxWidth="{StaticResource ContentMaxWidthForm}">
            <TextBlock Text="{loc:Loc settings.section.license}" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- License Status Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{loc:Loc settings.license.status.title}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="LicenseStatusText" Text="{loc:Loc license.status.trial.title}"
                                       FontSize="12" Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="LicenseEmailText" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="Collapsed" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Status Badge -->
                        <Border x:Name="LicenseStatusBadge" Grid.Column="1"
                                Background="{DynamicResource WarningBackgroundBrush}" CornerRadius="{StaticResource ButtonCornerRadius}"
                                Padding="8,4" VerticalAlignment="Top">
                            <TextBlock x:Name="LicenseStatusBadgeText" Text="{loc:Loc license.status.trial.title}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarningForegroundBrush}"/>
                        </Border>
                    </Grid>

                    <Border x:Name="LicenseActivationDivider" Height="1" Background="{DynamicResource BorderBrush}"
                            Margin="0,14,0,14"/>

                    <StackPanel x:Name="LicenseActivationPanel">
                        <TextBlock Text="{loc:Loc settings.license.activate.title}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{loc:Loc settings.license.activate.subtitle}"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,12" TextWrapping="Wrap"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LicenseKeyBox" FontFamily="Consolas"/>
                            <Button x:Name="ActivateLicenseButton" Grid.Column="1"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="{loc:Loc license.button.activate}" Margin="8,0,0,0"
                                    Click="ActivateLicense_Click"/>
                        </Grid>

                        <!-- Activation Error Message -->
                        <TextBlock x:Name="LicenseErrorText" Visibility="Collapsed"
                                   FontSize="12" Foreground="{DynamicResource ErrorForegroundBrush}" Margin="0,8,0,0"
                                   TextWrapping="Wrap"/>

                        <!-- Purchase Link -->
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <TextBlock Text="{loc:Loc settings.license.nolicense.prompt}" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock FontSize="12">
                                <Hyperlink Click="PurchaseLicense_Click" Foreground="{DynamicResource AccentBrush}">
                                    <Run Text="{loc:Loc settings.license.nolicense.link}"/>
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Licensed User Actions (hidden by default) -->
                    <StackPanel x:Name="LicensedUserActions" Visibility="Collapsed" Margin="0,16,0,0" Orientation="Horizontal">
                        <Button Content="{loc:Loc license.button.manageBilling}"
                                HorizontalAlignment="Left"
                                Click="ManageSubscription_Click"/>
                        <Button Content="{loc:Loc license.button.deactivate}"
                                Margin="8,0,0,0" HorizontalAlignment="Left"
                                Click="DeactivateLicense_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
