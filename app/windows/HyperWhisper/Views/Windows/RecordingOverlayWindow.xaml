<Window x:Class="HyperWhisper.Views.Windows.RecordingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HyperWhisper.Localization"
        Title="{loc:Loc recording.state.recording}"
        Width="200" Height="40"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Pill-shaped container matching macOS design -->
    <Border x:Name="MainBorder"
            CornerRadius="20"
            Background="#D9000000"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1">
        <!-- Drop shadow effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.3"
                              BlurRadius="20"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="8,0">
            <!-- Recording State -->
            <Grid x:Name="RecordingState" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stop Button -->
                <Button x:Name="StopButton"
                        Grid.Column="0"
                        Width="24" Height="24"
                        Click="StopButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="StopButtonBg"
                                         Fill="#E6FF3B30"/>
                                <Rectangle Width="10" Height="10"
                                           Fill="White"
                                           RadiusX="2" RadiusY="2"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="StopButtonBg" Property="Fill" Value="#F2FF3B30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Mode Badge - Compact pill shape -->
                <Border Grid.Column="1"
                        Background="#26FFFFFF"
                        CornerRadius="9"
                        Padding="6,3"
                        Margin="6,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StreamingDot"
                                 Width="6" Height="6"
                                 Fill="{DynamicResource SuccessBrush}"
                                 Visibility="Collapsed"
                                 Margin="0,0,4,0"/>
                        <TextBlock x:Name="ModeBadge"
                                   Text="Hyper"
                                   Foreground="#E6FFFFFF"
                                   FontSize="9"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Waveform Canvas -->
                <Canvas x:Name="WaveformCanvas"
                        Grid.Column="2"
                        ClipToBounds="True"/>
            </Grid>

            <!-- Transcribing State -->
            <Grid x:Name="TranscribingState" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!-- Spinner -->
                    <Ellipse x:Name="Spinner"
                             Width="16" Height="16"
                             Stroke="White"
                             StrokeThickness="2"
                             StrokeDashArray="2,2"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <!-- Status Text -->
                    <TextBlock x:Name="StatusText"
                               Text="{loc:Loc recording.state.transcribing}"
                               Foreground="#E6FFFFFF"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Success State -->
            <Grid x:Name="SuccessState" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!-- Checkmark Circle -->
                    <Grid Width="18" Height="18">
                        <Ellipse Fill="{DynamicResource SuccessBrush}"/>
                        <Path Data="M5,9 L8,12 L13,6"
                              Stroke="White"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Margin="2"/>
                    </Grid>
                    <!-- Success Text -->
                    <TextBlock Text="{loc:Loc recording.success.pasted}"
                               Foreground="#E6FFFFFF"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Copied State (clipboard-only, no paste) -->
            <Grid x:Name="CopiedState" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!-- Clipboard Circle (Blue) -->
                    <Grid Width="18" Height="18">
                        <Ellipse Fill="{DynamicResource SuccessBrush}"/>
                        <!-- Clipboard icon: simple rectangle with tab -->
                        <Path Data="M6,4 L6,14 L13,14 L13,4 Z M8,3 L11,3 L11,5 L8,5 Z"
                              Fill="White"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Margin="2"/>
                    </Grid>
                    <!-- Copied Text -->
                    <TextBlock Text="{loc:Loc recording.copy.copied}"
                               Foreground="#E6FFFFFF"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Cancel Confirmation State -->
            <!-- Matches macOS design: "Cancel?" text with No/Yes buttons -->
            <!-- No button (Escape): dismisses confirmation, resumes recording -->
            <!-- Yes button (Enter): confirms cancellation, discards recording -->
            <Grid x:Name="CancelConfirmationState" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel? text -->
                <TextBlock Grid.Column="0"
                           Text="{loc:Loc recording.cancel.prompt}"
                           Foreground="#E6FFFFFF"
                           FontSize="9"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>

                <!-- Spacer -->
                <Grid Grid.Column="1"/>

                <!-- No Button (Escape) -->
                <Button x:Name="NoButton"
                        Grid.Column="2"
                        Click="NoButton_Click"
                        Cursor="Hand"
                        Margin="0,0,6,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="NoBorder"
                                    Background="#33FFFFFF"
                                    CornerRadius="11"
                                    Padding="10,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc common.no}"
                                               Foreground="White"
                                               FontSize="9"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="(Esc)"
                                               Foreground="#B3FFFFFF"
                                               FontSize="9"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="NoBorder" Property="Background" Value="#4DFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Yes Button (Enter) - Red background like macOS -->
                <Button x:Name="YesButton"
                        Grid.Column="3"
                        Click="YesButton_Click"
                        Cursor="Hand"
                        Margin="0,0,4,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="YesBorder"
                                    Background="#CCFF3B30"
                                    CornerRadius="11"
                                    Padding="10,5">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc common.yes}"
                                               Foreground="White"
                                               FontSize="9"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="(Enter)"
                                               Foreground="#B3FFFFFF"
                                               FontSize="9"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="YesBorder" Property="Background" Value="#E6FF3B30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
