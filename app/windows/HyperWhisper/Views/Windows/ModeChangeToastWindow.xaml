<Window x:Class="HyperWhisper.Views.Windows.ModeChangeToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="200" Height="36"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Mode Change Toast: Pill-shaped notification matching macOS ModeChangeToast design -->
    <Border x:Name="MainBorder"
            CornerRadius="18"
            Background="#D9000000"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.3"
                              BlurRadius="10"
                              ShadowDepth="4"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <!-- Sparkles icon -->
            <TextBlock Text="&#x2728;"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#E6FFFFFF"
                       VerticalAlignment="Center"/>

            <!-- 8px spacing -->
            <TextBlock x:Name="ModeText"
                       Text="Mode: Default"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="#E6FFFFFF"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="150"
                       Margin="8,0,0,0"/>
        </StackPanel>
    </Border>
</Window>
