<Window x:Class="HyperWhisper.Views.Windows.UpdateToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HyperWhisper.Localization"
        Title="Update Available"
        Width="300" Height="44"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Toast pill matching ErrorToastWindow design -->
    <Border x:Name="MainBorder"
            CornerRadius="20"
            Background="#D9000000"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1"
            Opacity="0"
            Cursor="Hand"
            MouseLeftButtonUp="Border_MouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.3"
                              BlurRadius="20"
                              ShadowDepth="0"/>
        </Border.Effect>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="14,0">

            <!-- Up arrow icon -->
            <Path Data="M6,10 L6,2 M2,5 L6,1 L10,5"
                  Stroke="{DynamicResource AccentBrush}"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Width="12" Height="12"
                  Stretch="Uniform"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"/>

            <!-- Toast message -->
            <TextBlock Text="{loc:Loc update.toast}"
                       Foreground="#E6FFFFFF"
                       FontSize="11"
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
