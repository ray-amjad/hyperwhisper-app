<Window x:Class="HyperWhisper.Views.Windows.UpdateMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HyperWhisper.Localization"
        Title="HyperWhisper"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Background="{DynamicResource ContentBackgroundBrush}">

    <StackPanel Margin="24,20">
        <!-- Icon + Title row -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <!-- Success icon (checkmark) -->
            <Grid x:Name="SuccessIcon" Width="20" Height="20" Margin="0,0,10,0" Visibility="Collapsed">
                <Ellipse Fill="{DynamicResource SuccessBrush}" Opacity="0.15"/>
                <Path Data="M4,10 L8,14 L16,6"
                      Stroke="{DynamicResource SuccessBrush}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Stretch="Uniform"
                      Width="12" Height="12"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"/>
            </Grid>

            <!-- Error icon (warning triangle) -->
            <Grid x:Name="ErrorIcon" Width="20" Height="20" Margin="0,0,10,0" Visibility="Collapsed">
                <Path Data="M10,2 L19,18 L1,18 Z"
                      Fill="{DynamicResource ErrorBrush}"
                      Opacity="0.15"
                      Stretch="Uniform"/>
                <TextBlock Text="!"
                           Foreground="{DynamicResource ErrorBrush}"
                           FontSize="11"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,3,0,0"/>
            </Grid>

            <!-- Info icon -->
            <Grid x:Name="InfoIcon" Width="20" Height="20" Margin="0,0,10,0" Visibility="Collapsed">
                <Ellipse Fill="{DynamicResource AccentBrush}" Opacity="0.15"/>
                <TextBlock Text="i"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Message body -->
        <TextBlock x:Name="MessageText"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <!-- OK button -->
        <Button Content="{loc:Loc common.ok}"
                Style="{StaticResource PrimaryButtonStyle}"
                HorizontalAlignment="Right"
                MinWidth="80"
                Click="OkButton_Click"
                IsDefault="True"/>
    </StackPanel>
</Window>
