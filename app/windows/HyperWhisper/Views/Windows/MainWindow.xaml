<Window x:Class="HyperWhisper.Views.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HyperWhisper.ViewModels"
        xmlns:loc="clr-namespace:HyperWhisper.Localization"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{loc:Loc app.title}" Width="1000" Height="680"
        MinWidth="1000" MinHeight="680" MaxWidth="1000" MaxHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        Background="Transparent">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource SidebarWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title area. WindowChrome makes this row draggable. -->
        <Border Grid.ColumnSpan="2"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MinimizeButton_Click"
                            ToolTip="{loc:Loc window.caption.minimize}"
                            AutomationProperties.Name="{loc:Loc window.caption.minimize}">
                        <Path Width="10" Height="2" Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M0,0 H10"/>
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="MaximizeButton_Click"
                            Visibility="Collapsed"
                            ToolTip="{loc:Loc window.caption.maximize}"
                            AutomationProperties.Name="{loc:Loc window.caption.maximize}">
                        <Path Width="10" Height="10" Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              Data="M1,1 H9 V9 H1 Z"/>
                    </Button>
                    <Button Style="{StaticResource CaptionButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="{loc:Loc window.caption.close}"
                            AutomationProperties.Name="{loc:Loc window.caption.close}">
                        <Path Width="10" Height="10" Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M1,1 L9,9 M9,1 L1,9"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Height="54">
                    <TextBlock Text="{loc:Loc app.title}"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource SidebarGroupStyle}" Margin="10,0">
                    <StackPanel>
                    <RadioButton Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc sidebar.home}" IsChecked="True" Command="{Binding NavigateToHomeCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF9A4D" Offset="0"/>
                                <GradientStop Color="#F05A28" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <Border Height="14"/>
                    <RadioButton Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc sidebar.modes}" Command="{Binding NavigateToModesCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#49A5FF" Offset="0"/>
                                <GradientStop Color="#236DFF" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc sidebar.vocabulary}" Command="{Binding NavigateToVocabularyCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#49A5FF" Offset="0"/>
                                <GradientStop Color="#236DFF" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M19,2L14,6.5V17.5L19,13V2M6.5,5C4.55,5 2.45,5.4 1,6.5V21.16C1,21.41 1.25,21.66 1.5,21.66C1.6,21.66 1.65,21.59 1.75,21.59C3.1,20.94 5.05,20.5 6.5,20.5C8.45,20.5 10.55,20.9 12,22C13.35,21.15 15.8,20.5 17.5,20.5C19.15,20.5 20.85,20.81 22.25,21.56C22.35,21.61 22.4,21.59 22.5,21.59C22.75,21.59 23,21.34 23,21.09V6.5C22.4,6.05 21.75,5.75 21,5.5V19C19.9,18.65 18.7,18.5 17.5,18.5C15.8,18.5 13.35,19.15 12,20V6.5C10.55,5.4 8.45,5 6.5,5Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <Border Height="14"/>
                    <RadioButton x:Name="ModelLibraryNavButton" Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc settings.nav.models}" Command="{Binding NavigateToModelLibraryCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8A7CFF" Offset="0"/>
                                <GradientStop Color="#5B4BDB" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M4,5A2,2 0 0,1 6,3H18A2,2 0 0,1 20,5V19A2,2 0 0,1 18,21H6A2,2 0 0,1 4,19V5M7,7V11H11V7H7M13,7V11H17V7H13M7,13V17H11V13H7M13,13V17H17V13H13Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <RadioButton Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc settings.nav.streaming}" Command="{Binding NavigateToStreamingCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8A7CFF" Offset="0"/>
                                <GradientStop Color="#5B4BDB" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M12,14A3,3 0,0 0,15 11V5A3,3 0,0 0,12 2A3,3 0,0 0,9 5V11A3,3 0,0 0,12 14M17.3,11A5.3,5.3 0,0 1,12 16.3A5.3,5.3 0,0 1,6.7 11H5A7,7 0,0 0,11 17.9V21H13V17.9A7,7 0,0 0,19 11H17.3Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <Border Height="14"/>
                    <RadioButton Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc sidebar.history}" Command="{Binding NavigateToHistoryCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C74FF" Offset="0"/>
                                <GradientStop Color="#4A42D8" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M13.5,8H12V13L16.28,15.54L17,14.33L13.5,12.25V8M13,3A9,9 0 0,0 4,12H1L4.96,16.03L9,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.07,19 9.32,18.21 8.06,16.94L6.64,18.36C8.27,20 10.5,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    <Border Height="14"/>
                    <RadioButton x:Name="SettingsNavButton" Style="{StaticResource SidebarItemStyle}" Content="{loc:Loc sidebar.settings}" Command="{Binding NavigateToSettingsCommand}" GroupName="Nav">
                        <RadioButton.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#73777F" Offset="0"/>
                                <GradientStop Color="#3F444C" Offset="1"/>
                            </LinearGradientBrush>
                        </RadioButton.BorderBrush>
                        <RadioButton.Tag>
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Fill="{DynamicResource TextOnAccentBrush}" Width="14" Height="14" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="2" Margin="10,0,10,10">
                    <Separator Background="{DynamicResource BorderBrush}" Opacity="0.5" Margin="10,8"/>

                    <Border x:Name="LicensedSidebarCard"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SidebarGroupCornerRadius}"
                            Padding="14,8"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Loc app.title}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource HoverBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ButtonCornerRadius}"
                                    Padding="6,2"
                                    Margin="8,0,0,0">
                                <TextBlock Text="{loc:Loc app.badge.pro}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Cloud credits CTA (for users without an active Cloud license).
                         Local transcription is free & unlimited (open source); this is a
                         discoverable path to HyperWhisper Cloud (paid, credit-based). -->
                    <StackPanel x:Name="CloudSidebarActions">
                        <Button Click="CloudCreditsSidebar_Click"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,8"
                                HorizontalContentAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE753;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{loc:Loc app.cloud.cta.title}"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Frame -->
        <Frame x:Name="ContentFrame" Grid.Column="1" Grid.Row="1" NavigationUIVisibility="Hidden" Background="{DynamicResource ContentBackgroundBrush}"/>

        <!-- Status Bar -->
        <Border Grid.Column="1" Grid.Row="2" Style="{StaticResource StatusBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="6" Height="6"
                             Fill="{DynamicResource WarningForegroundBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock Text="{loc:Loc statusbar.postProcessing}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding LocalPostProcessingStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                    <StackPanel.Visibility>
                        <Binding Path="HasLocalPostProcessingStatus" Converter="{StaticResource BoolToVisibilityConverter}"/>
                    </StackPanel.Visibility>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="{loc:Loc statusbar.mode}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding CurrentMode.Name, FallbackValue='None'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="Medium"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc statusbar.model}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding ModelStatus}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
