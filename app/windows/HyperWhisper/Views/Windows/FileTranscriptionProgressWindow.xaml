<Window x:Class="HyperWhisper.Views.Windows.FileTranscriptionProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HyperWhisper.Localization"
        Title="File Transcription Progress"
        Width="300" Height="110"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Pill-shaped container matching RecordingOverlayWindow design -->
    <Border x:Name="MainBorder"
            CornerRadius="12"
            Background="#D9000000"
            BorderBrush="#1AFFFFFF"
            BorderThickness="1">
        <!-- Drop shadow effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Opacity="0.3"
                              BlurRadius="20"
                              ShadowDepth="0"/>
        </Border.Effect>

        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: File Name -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">
                <TextBlock Text="📄"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock x:Name="FileNameText"
                           Text="filename.mp3"
                           Foreground="#E6FFFFFF"
                           FontSize="12"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Row 1: Progress Bar and Percentage -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Progress Bar -->
                <Border Grid.Column="0"
                        Height="6"
                        CornerRadius="3"
                        Background="#26FFFFFF"
                        Margin="0,0,8,0"
                        x:Name="ProgressBarTrack">
                    <Border x:Name="ProgressFill"
                            HorizontalAlignment="Left"
                            CornerRadius="3"
                            Width="0"
                            Background="{DynamicResource AccentBrush}"/>
                </Border>

                <!-- Percentage Text -->
                <TextBlock Grid.Column="1"
                           x:Name="PercentageText"
                           Text="0%"
                           Foreground="#99FFFFFF"
                           FontSize="10"
                           FontWeight="Medium"
                           FontFamily="Consolas"
                           Width="32"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Row 2: Cancel Button -->
            <Button Grid.Row="2"
                    x:Name="CancelButton"
                    Click="CancelButton_Click"
                    Cursor="Hand"
                    HorizontalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CancelBorder"
                                Background="#1AFFFFFF"
                                CornerRadius="9"
                                Padding="12,4">
                            <TextBlock Text="{loc:Loc common.cancel}"
                                       Foreground="#B3FFFFFF"
                                       FontSize="10"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CancelBorder" Property="Background" Value="#4DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
