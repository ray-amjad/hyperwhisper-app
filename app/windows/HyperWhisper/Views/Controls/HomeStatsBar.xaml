<UserControl x:Class="HyperWhisper.Views.Controls.HomeStatsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:HyperWhisper.Localization">
    <Border CornerRadius="12"
            Padding="20,14"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <WrapPanel Orientation="Horizontal">
            <!-- Avg WPM -->
            <StackPanel Width="132"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <TextBlock FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding AverageWpm, Mode=OneWay}"/>
                    <Run Text=" WPM"/>
                </TextBlock>
                <TextBlock Text="{loc:Loc home.stats.averageSpeed}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Width="1" Height="32" Margin="8,0,8,10" VerticalAlignment="Center" Background="{DynamicResource BorderBrush}"/>

            <!-- Words this week -->
            <StackPanel Width="132"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding WordsThisWeek, Mode=OneWay}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{loc:Loc home.stats.wordsThisWeek}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Width="1" Height="32" Margin="8,0,8,10" VerticalAlignment="Center" Background="{DynamicResource BorderBrush}"/>

            <!-- Words this month -->
            <StackPanel Width="132"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding WordsThisMonth, Mode=OneWay}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{loc:Loc home.stats.wordsThisMonth}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Border Width="1" Height="32" Margin="8,0,8,10" VerticalAlignment="Center" Background="{DynamicResource BorderBrush}"/>

            <!-- Saved this week (with gear menu) -->
            <StackPanel Width="132"
                        Margin="0,0,0,10"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding SavedThisWeekDisplay, Mode=OneWay}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc home.stats.savedThisWeek}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button x:Name="TypingSpeedButton"
                            Grid.Column="1"
                            Width="14" Height="14"
                            Margin="4,0,0,0"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            Cursor="Hand"
                            ToolTip="{loc:Loc home.stats.typingSpeedHelp}"
                            Click="TypingSpeedButton_Click">
                        <Path Width="10" Height="10" Stretch="Uniform"
                              Fill="{DynamicResource TextSecondaryBrush}"
                              Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="TypingSpeedMenu" Placement="Bottom">
                                <MenuItem Header="30 WPM" Tag="30" Click="TypingSpeedMenuItem_Click"/>
                                <MenuItem Header="40 WPM" Tag="40" Click="TypingSpeedMenuItem_Click"/>
                                <MenuItem Header="50 WPM" Tag="50" Click="TypingSpeedMenuItem_Click"/>
                                <MenuItem Header="60 WPM" Tag="60" Click="TypingSpeedMenuItem_Click"/>
                                <MenuItem Header="80 WPM" Tag="80" Click="TypingSpeedMenuItem_Click"/>
                                <MenuItem Header="100 WPM" Tag="100" Click="TypingSpeedMenuItem_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </StackPanel>
        </WrapPanel>
    </Border>
</UserControl>
