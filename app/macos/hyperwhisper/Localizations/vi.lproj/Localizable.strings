// MARK: - Post-Processing Model Descriptions
"models.postProcessing.hyperwhisper.description" = "Xử lý sau AI tích hợp chạy trên Cloudflare Workers. Không cần cấu hình.";
"models.postProcessing.gpt4.1.nano.description" = "Độ chính xác trung bình (92%), tốc độ rất nhanh (<1s). Phù hợp với bản nháp nhanh và ghi chú không chính thức.";
"models.postProcessing.gpt4.1.mini.description" = "Độ chính xác cao (94%), tốc độ nhanh (~1-2s). Tốt cho các giao tiếp kinh doanh hàng ngày và tài liệu tiêu chuẩn.";
"models.postProcessing.gpt4.1.description" = "Độ chính xác rất cao (96%), tốc độ trung bình (~3-4s). Tuyệt vời cho định dạng phức tạp và nội dung kỹ thuật.";
"models.postProcessing.gpt5.nano.description" = "Độ chính xác tốt (95%), tốc độ nhanh nhất (~1s). Hoàn hảo cho ghi chú nhanh, tin nhắn và bản chuyển đổi bình thường.";
"models.postProcessing.gpt5.mini.description" = "Độ chính xác xuất sắc (97%), tốc độ trung bình (~2-3s). Lý tưởng cho email chuyên nghiệp, báo cáo và ghi chú cuộc họp.";
"models.postProcessing.gpt5.description" = "Độ chính xác cao nhất (99%+), tốc độ chậm nhất (~3-5s). Tốt nhất cho tài liệu quan trọng, pháp lý, bản chuyển đổi y tế nơi độ chính xác là tối quan trọng.";
"models.postProcessing.gpt5.1.description" = "Độ chính xác tối tân (98%+), tốc độ trung bình (~2-3s). Xuất sắc cho các tác vụ phức tạp, tài liệu pháp lý và nội dung kỹ thuật với suy luận vượt trội.";
"models.postProcessing.gpt5.2.description" = "Loạt GPT-5 mới nhất với suy luận nâng cao và suy luận nhanh hơn. Lựa chọn tốt nhất cho xử lý văn bản chất lượng cao.";
"models.postProcessing.claude4.5.haiku.description" = "Claude Haiku mới nhất với suy luận được cải thiện trong khi giữ thời gian phản ứng nhanh.";
"models.postProcessing.claude4.sonnet.description" = "Hiệu suất cân bằng. Khả năng suy luận vượt trội và định dạng cho các tài liệu chuyên nghiệp.";
