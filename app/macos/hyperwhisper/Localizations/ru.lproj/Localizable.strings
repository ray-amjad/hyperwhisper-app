// MARK: - Post-Processing Model Descriptions
"models.postProcessing.hyperwhisper.description" = "Встроенная постобработка ИИ работает на Cloudflare Workers. Никаких настроек не требуется.";
"models.postProcessing.gpt4.1.nano.description" = "Умеренная точность (92%), очень быстрая скорость (<1s). Подходит для быстрых черновиков и неформальных заметок.";
"models.postProcessing.gpt4.1.mini.description" = "Высокая точность (94%), быстрая скорость (~1-2s). Хорошо для повседневных деловых сообщений и стандартных документов.";
"models.postProcessing.gpt4.1.description" = "Очень высокая точность (96%), умеренная скорость (~3-4s). Отлично подходит для сложного форматирования и технического содержимого.";
"models.postProcessing.gpt5.nano.description" = "Хорошая точность (95%), самая быстрая скорость (~1s). Идеально для быстрых заметок, сообщений и повседневных транскрипций.";
"models.postProcessing.gpt5.mini.description" = "Отличная точность (97%), умеренная скорость (~2-3s). Идеальный баланс для профессиональных писем, отчетов и заметок встречи.";
"models.postProcessing.gpt5.description" = "Наивысшая точность (99%+), самая медленная скорость (~3-5s). Лучше для критических документов, юридических и медицинских транскрипций, где точность крайне важна.";
"models.postProcessing.gpt5.1.description" = "Самая современная точность (98%+), умеренная скорость (~2-3s). Отлично подходит для сложных задач, юридических документов и технического содержимого с превосходным рассуждением.";
"models.postProcessing.gpt5.2.description" = "Последняя серия GPT-5 с улучшенным рассуждением и более быстрым выводом. Лучший общий выбор для качественной обработки текста.";
"models.postProcessing.claude4.5.haiku.description" = "Последний Claude Haiku с улучшенным рассуждением при сохранении быстрого времени отклика.";
"models.postProcessing.claude4.sonnet.description" = "Сбалансированная производительность. Превосходные возможности рассуждения и форматирования для профессиональных документов.";
"models.postProcessing.gemini3.flash.description" = "Серия Gemini 3 с интеллектом уровня Pro со скоростью Flash. Продвинутое рассуждение с возможностью динамического мышления.";
"models.postProcessing.gemini2.5.flash.description" = "Лучший с точки зрения соотношения цены и производительности. Оптимизирован для скорости при сохранении хорошей точности для повседневного использования.";
"models.postProcessing.gemini2.5.flashLite.description" = "Ультра быстрая модель, оптимизированная для экономичности и высокой производительности.";
"models.postProcessing.groq.llama33.70b.description" = "Универсальная модель 70B с отличным качеством. ~280 tokens/sec. Рекомендуется.";
"models.postProcessing.groq.llama31.8b.description" = "Ультра-быстрая модель 8B. ~560 tokens/sec для мгновенной обработки текста.";
"models.postProcessing.groq.gptoss.120b.description" = "Открытая модель OpenAI 120B. ~500 tokens/sec для качественной обработки.";
"models.postProcessing.groq.gptoss.20b.description" = "Легкая модель 20B. ~1000 tokens/sec для самой быстрой обработки.";
"models.postProcessing.cerebras.gptoss.120b.description" = "GPT OSS 120B на Cerebras. Ультра-быстрая модель 120B с ~3000 tokens/sec. Рекомендуется.";
