// MARK: - Post-Processing Model Descriptions
"models.postProcessing.hyperwhisper.description" = "Ενσωματωμένη μετα-επεξεργασία τεχνητής νοημοσύνης που εκτελείται σε Cloudflare Workers. Δεν απαιτείται διαμόρφωση.";
"models.postProcessing.gpt4.1.nano.description" = "Μεσαία ακρίβεια (92%), πολύ γρήγορη ταχύτητα (<1s). Κατάλληλο για γρήγορα προσχέδια και άτυπες σημειώσεις.";
"models.postProcessing.gpt4.1.mini.description" = "Υψηλή ακρίβεια (94%), γρήγορη ταχύτητα (~1-2s). Καλό για επιχειρηματικές επικοινωνίες καθημερινής χρήσης και τυπικά έγγραφα.";
"models.postProcessing.gpt4.1.description" = "Πολύ υψηλή ακρίβεια (96%), μέτρια ταχύτητα (~3-4s). Μεγάλο για σύνθετη μορφοποίηση και τεχνικό περιεχόμενο.";
"models.postProcessing.gpt5.nano.description" = "Καλή ακρίβεια (95%), γρηγορότερη ταχύτητα (~1s). Τέλειο για γρήγορες σημειώσεις, μηνύματα και περιστασιακές μεταγραφές.";
"models.postProcessing.gpt5.mini.description" = "Εξαιρετική ακρίβεια (97%), μέτρια ταχύτητα (~2-3s). Ιδανική ισορροπία για επαγγελματικά ηλεκτρονικά, αναφορές και σημειώσεις συνάντησης.";
"models.postProcessing.gpt5.description" = "Υψηλότερη ακρίβεια (99%+), πιο αργή ταχύτητα (~3-5s). Καλύτερο για κρίσιμα έγγραφα, νομικές, ιατρικές μεταγραφές όπου η ακρίβεια είναι παραμούσια.";
"models.postProcessing.gpt5.1.description" = "Σημερινή τέχνη ακρίβεια (98%+), μέτρια ταχύτητα (~2-3s). Εξαιρετικό για σύνθετα καθήκοντα, νομικά έγγραφα και τεχνικό περιεχόμενο με ανώτερη συλλογιστική.";
"models.postProcessing.gpt5.2.description" = "Τελευταίες σειρές GPT-5 με ενισχυμένη συλλογιστική και ταχύτερη συμπερασματολογία. Καλύτερη συνολική επιλογή για υψηλής ποιότητας επεξεργασία κειμένου.";
"models.postProcessing.claude4.5.haiku.description" = "Τελευταία Claude Haiku με βελτιωμένη συλλογιστική ενώ κρατά τους χρόνους απόκρισης ζωηρά.";
"models.postProcessing.claude4.sonnet.description" = "Ισορροπημένη απόδοση. Ανώτερη συλλογιστική και δυνατότητες μορφοποίησης για επαγγελματικά έγγραφα.";
"models.postProcessing.gemini3.flash.description" = "Σειρές Gemini 3 με νοημοσύνη επιπέδου Pro σε ταχύτητα Flash. Προηγμένη συλλογιστική με δυναμικές δυνατότητες σκέψης.";
"models.postProcessing.gemini2.5.flash.description" = "Καλύτερο στην τιμή-απόδοση. Βελτιστοποιημένο για ταχύτητα ενώ διατηρεί καλή ακρίβεια για καθημερινή χρήση.";
"models.postProcessing.gemini2.5.flashLite.description" = "Υπερ-ταχύ μοντέλο βελτιστοποιημένο για αποτελεσματικότητα κόστους και υψηλή απόδοση.";
"models.postProcessing.groq.llama33.70b.description" = "Ευέλικτο μοντέλο 70B με εξαιρετική ποιότητα. ~280 tokens/sec. Συνιστάται.";
