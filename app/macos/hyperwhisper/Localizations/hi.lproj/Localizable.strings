// MARK: - Post-Processing Model Descriptions
"models.postProcessing.hyperwhisper.description" = "Cloudflare Workers पर चलने वाली बिल्कुल नई AI बाद में प्रोसेसिंग। कोई कॉन्फ़िगरेशन आवश्यक नहीं।";
"models.postProcessing.gpt4.1.nano.description" = "मध्यम सटीकता (92%), बहुत तेज़ गति (<1s)। त्वरित ड्राफ्ट और अनौपचारिक नोट्स के लिए उपयुक्त।";
"models.postProcessing.gpt4.1.mini.description" = "उच्च सटीकता (94%), तेज़ गति (~1-2s)। रोज़मर्रा के व्यावसायिक संचार और मानक दस्तावेजों के लिए अच्छा।";
"models.postProcessing.gpt4.1.description" = "बहुत उच्च सटीकता (96%), मध्यम गति (~3-4s)। जटिल फॉर्मेटिंग और तकनीकी सामग्री के लिए बहुत अच्छा।";
"models.postProcessing.gpt5.nano.description" = "अच्छी सटीकता (95%), सबसे तेज़ गति (~1s)। त्वरित नोट्स, संदेश और आकस्मिक ट्रांसक्रिप्शन के लिए परफेक्ट।";
"models.postProcessing.gpt5.mini.description" = "उत्कृष्ट सटीकता (97%), मध्यम गति (~2-3s)। व्यावसायिक ईमेल, रिपोर्ट और मीटिंग नोट्स के लिए आदर्श संतुलन।";
"models.postProcessing.gpt5.description" = "सर्वोच्च सटीकता (99%+), सबसे धीमी गति (~3-5s)। महत्वपूर्ण दस्तावेज, कानूनी, चिकित्सा ट्रांसक्रिप्शन के लिए सर्वोत्तम जहां परिशुद्धता सर्वोपरि है।";
"models.postProcessing.gpt5.1.description" = "अत्याधुनिक सटीकता (98%+), मध्यम गति (~2-3s)। जटिल कार्यों, कानूनी दस्तावेज़ और बेहतर तर्क के साथ तकनीकी सामग्री के लिए उत्कृष्ट।";
"models.postProcessing.gpt5.2.description" = "बेहतर तर्क और तेज़ आह्वान के साथ नवीनतम GPT-5 श्रृंखला। उच्च-गुणवत्ता पाठ प्रसंस्करण के लिए सर्वोत्तम समग्र विकल्प।";
"models.postProcessing.claude4.5.haiku.description" = "प्रतिक्रिया समय तेज़ रखते हुए बेहतर तर्क के साथ नवीनतम Claude Haiku।";
"models.postProcessing.claude4.sonnet.description" = "संतुलित प्रदर्शन। व्यावसायिक दस्तावेजों के लिए उच्चतर तर्क और फॉर्मेटिंग क्षमता।";
"models.postProcessing.gemini3.flash.description" = "Pro-स्तरीय बुद्धि के साथ Gemini 3 श्रृंखला फ्लैश गति पर। गतिशील सोच क्षमताओं के साथ उन्नत तर्क।";
"models.postProcessing.gemini2.5.flash.description" = "मूल्य-प्रदर्शन के मामले में सर्वोत्तम। रोज़मर्रा के उपयोग के लिए अच्छी सटीकता को बनाए रखते हुए गति के लिए अनुकूलित।";
