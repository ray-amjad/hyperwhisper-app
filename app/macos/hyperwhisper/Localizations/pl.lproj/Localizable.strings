"models.postProcessing.gpt4.1.nano.description" = "Umiarkowana dokładność (92%), bardzo szybka prędkość (<1s). Odpowiednie do szybkich szkiców i nieformalnych notatek.";
"models.postProcessing.gpt4.1.mini.description" = "Wysoka dokładność (94%), szybka prędkość (~1-2s). Dobra do codziennej komunikacji biznesowej i standardowych dokumentów.";
