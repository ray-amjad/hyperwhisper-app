// MARK: - Post-Processing Model Descriptions
"models.postProcessing.hyperwhisper.description" = "Вбудована постобробка ШІ на Cloudflare Workers. Нічого налаштовувати не потрібно.";
"models.postProcessing.gpt4.1.nano.description" = "Середня точність (92%), дуже швидко (<1с). Підходить для швидких чернеток та неформальних замітки.";
"models.postProcessing.gpt4.1.mini.description" = "Висока точність (94%), швидко (~1-2с). Добре для повсякденних ділових комунікацій та стандартних документів.";
"models.postProcessing.gpt4.1.description" = "Дуже висока точність (96%), помірна швидкість (~3-4с). Чудово для складного форматування та технічного контенту.";
"models.postProcessing.gpt5.nano.description" = "Добра точність (95%), найшвидша швидкість (~1с). Ідеально для швидких замітки, повідомлень та випадкових транскрипцій.";
"models.postProcessing.gpt5.mini.description" = "Відмінна точність (97%), помірна швидкість (~2-3с). Ідеальний баланс для професійних електронних листів, звітів та нотатків зустріч.";
"models.postProcessing.gpt5.description" = "Найвища точність (99%+), найповільніша швидкість (~3-5с). Найкраще для критичних документів, юридичних, медичних транскрипцій, де точність є найголовнішою.";
"models.postProcessing.gpt5.1.description" = "Найновітніша точність ШІ (98%+), помірна швидкість (~2-3с). Відмінно для складних завдань, юридичних документів та технічного контенту з вищим рівнем розумування.";
"models.postProcessing.gpt5.2.description" = "Найновіша серія GPT-5 з покращеним розумуванням та швидшим виконанням. Найкращий загальний вибір для обробки тексту високої якості.";
"models.postProcessing.claude4.5.haiku.description" = "Найновіша Claude Haiku з покращеним розумуванням, зберігаючи швидкі час відповіді.";
"models.postProcessing.claude4.sonnet.description" = "Збалансована продуктивність. Вищий рівень розумування та можливостей форматування для професійних документів.";
"models.postProcessing.gemini3.flash.description" = "Серія Gemini 3 з інтелектом Pro-рівня на швидкості Flash. Передовим розумуванням з динамічною логікою мислення.";
"models.postProcessing.gemini2.5.flash.description" = "Найкраще співвідношення ціни та якості. Оптимізовано для швидкості зі збереженням хорошої точності для повсякденного використання.";
"models.postProcessing.gemini2.5.flashLite.description" = "Надшвидка модель, оптимізована для економії витрат та високої пропускної спроможності.";
"models.postProcessing.groq.llama33.70b.description" = "Універсальна модель 70B з відмінною якістю. ~280 токенів/сек. Рекомендовано.";
"models.postProcessing.groq.llama31.8b.description" = "Надшвидка модель 8B. ~560 токенів/сек для миттєвої обробки тексту.";
"models.postProcessing.groq.gptoss.120b.description" = "Відкрита модель OpenAI 120B. ~500 токенів/сек для обробки високої якості.";
"models.postProcessing.groq.gptoss.20b.description" = "Легка модель 20B. ~1000 токенів/сек для найшвидшої обробки.";
"models.postProcessing.cerebras.gptoss.120b.description" = "GPT OSS 120B на Cerebras. Надшвидка модель 120B на ~3000 токенів/сек. Рекомендовано.";
