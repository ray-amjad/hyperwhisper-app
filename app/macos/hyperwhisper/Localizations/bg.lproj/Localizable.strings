"models.postProcessing.hyperwhisper.description" = "Вградена ИИ последваща обработка, работеща на Cloudflare Workers. Не е необходима конфигурация.";
"models.postProcessing.gpt4.1.nano.description" = "Умерена точност (92%), много висока скорост (<1с). Подходящ за бързи чернови и неформални бележки.";
"models.postProcessing.gpt4.1.mini.description" = "Висока точност (94%), бърза скорост (~1-2с). Добър за ежедневни бизнес комуникации и стандартни документи.";
"models.postProcessing.gpt4.1.description" = "Много висока точност (96%), умерена скорост (~3-4с). Страхотен за сложно форматиране и техническо съдържание.";
"models.postProcessing.gpt5.nano.description" = "Добра точност (95%), най-висока скорост (~1с). Перфектен за бързи бележки, съобщения и неформални транскрипции.";
"models.postProcessing.gpt5.mini.description" = "Отлична точност (97%), умерена скорост (~2-3с). Идеален баланс за професионални имейли, доклади и бележки от срещи.";
